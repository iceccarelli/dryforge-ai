# All variables are OPTIONAL. The site builds and runs fully without them.

# Clerk (enables login + /dashboard demo). Get keys at https://dashboard.clerk.com
# If unset, auth UI is hidden and /dashboard shows the public demo.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase (not yet used by any page; client is lazily created only if set)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
