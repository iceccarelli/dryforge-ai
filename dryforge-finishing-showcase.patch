+          <h3 className="mt-4 text-2xl font-bold tracking-tight text-slate-900">
+            {view.title}
+          </h3>
+          <p className="mt-3 text-[15px] leading-relaxed text-slate-600">{view.detail}</p>
+
+          {/* Measurements */}
+          <div className="mt-6">
+            <div className="mb-3 text-[11px] font-bold uppercase tracking-[1.5px] text-slate-500">
+              Design-target specifications
+            </div>
+            <dl className="grid grid-cols-1 gap-2.5 sm:grid-cols-2">
+              {view.metrics.map((m) => (
+                <div
+                  key={m.label}
+                  className="flex items-start gap-3 rounded-xl border border-slate-200 bg-slate-50 p-3"
+                >
+                  <span className="mt-0.5 inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-lg bg-white text-[#F97316] ring-1 ring-slate-200">
+                    <m.icon className="h-4 w-4" />
+                  </span>
+                  <div className="min-w-0">
+                    <dt className="text-[11px] font-semibold uppercase tracking-wide text-slate-500">
+                      {m.label}
+                    </dt>
+                    <dd className="text-sm font-semibold text-slate-900">{m.value}</dd>
+                  </div>
+                </div>
+              ))}
+            </dl>
+          </div>
+
+          {/* Similar views */}
+          {similar.length > 0 && (
+            <div className="mt-7">
+              <div className="mb-3 text-[11px] font-bold uppercase tracking-[1.5px] text-slate-500">
+                Similar views · {view.phase}
+              </div>
+              <div className="flex gap-3 overflow-x-auto pb-1 df-rail">
+                {similar.map(({ v, i }) => (
+                  <button
+                    key={v.id}
+                    type="button"
+                    onClick={() => onIndex(i)}
+                    aria-label={`View ${v.title}`}
+                    className="group relative aspect-[3/4] w-20 shrink-0 overflow-hidden rounded-lg border border-slate-200 bg-slate-900 transition hover:border-[#F97316] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#F97316]"
+                  >
+                    <Image
+                      src={v.src}
+                      alt={`${v.title} — DryForge concept render`}
+                      fill
+                      sizes="80px"
+                      className="object-cover transition-transform duration-300 group-hover:scale-105"
+                    />
+                  </button>
+                ))}
+              </div>
+            </div>
+          )}
+
+          <p className="mt-7 flex items-start gap-2 border-t border-slate-100 pt-4 text-xs leading-relaxed text-slate-400">
+            <Info className="mt-0.5 h-3.5 w-3.5 shrink-0" />
+            Concept render. Specifications are disclosed engineering design targets —
+            not captured performance or a photo of deployed hardware.
+          </p>
+        </div>
+      </motion.div>
+    </motion.div>
+  );
+}
+
+/* ---------------------------------------------------------------------------
